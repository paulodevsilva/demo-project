generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String            @id @default(uuid())
  email             String            @unique
  name              String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  password          String
  workouts          Workout[]
  movements         Movement[]
  bodyWeightEntries BodyWeightEntry[]
  nutritionEntries  NutritionEntry[]
}

model Movement {
  id            String  @id @default(uuid())
  userId        String
  user          User    @relation(fields: [userId], references: [id])
  name          String
  isBodyweight  Boolean @default(false)
  defaultWeight Int?
  defaultReps   Int?
  sets          Set[]

  @@unique([userId, name])
  @@index([userId, isBodyweight])
}

model Workout {
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  id          String    @id @default(uuid())
  completedAt DateTime?
  sets        Set[]

  @@index([userId, completedAt(sort: Desc)])
}

model Set {
  id         String   @id @default(uuid())
  workoutId  String
  workout    Workout  @relation(fields: [workoutId], references: [id])
  movementId String
  movement   Movement @relation(fields: [movementId], references: [id])
  reps       Int
  weight     Int

  @@index([workoutId])
  @@index([movementId, workoutId])
}

model BodyWeightEntry {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  weight     Int
  measuredAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([userId, measuredAt(sort: Desc)])
}

model NutritionEntry {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  calories  Int
  protein   Int
  carbs     Int
  fat       Int
  measuredAt DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([userId, measuredAt(sort: Desc)])
}
